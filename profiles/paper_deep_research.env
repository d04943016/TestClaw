# MyOpenClaw deep-research defaults for:
# /Users/weikai/Library/CloudStorage/Dropbox/paper
#
# Usage:
# 1) Keep your API keys in .env
# 2) Add: MYOPENCLAW_PROFILE=profiles/paper_deep_research.env
# 3) Restart CLI
#
# Notes:
# - This file tunes retrieval/compression behavior only.
# - It does not include secret keys.

PAPER_ROOT=/Users/weikai/Library/CloudStorage/Dropbox/paper

# Main agent memory retrieval (semantic + keyword hybrid)
AGENT_EMBEDDING_MODEL=text-embedding-3-small
AGENT_EMBEDDING_BASE_URL=https://api.openai.com/v1
AGENT_MEMORY_SEMANTIC_WEIGHT=0.75
AGENT_MEMORY_TOP_K=8

# Main agent memory compression
MEMORY_SHORT_TERM_WINDOW=36
MEMORY_CHUNK_TARGET_TOKENS=900
MEMORY_ROLLUP_BATCH_SIZE=8

# Research skillpack retrieval (semantic + keyword hybrid)
SKILL_EMBEDDING_MODEL=text-embedding-3-small
SKILL_EMBEDDING_BASE_URL=https://api.openai.com/v1
SKILL_MEMORY_SEMANTIC_WEIGHT=0.78
SKILL_FILE_SCAN_LIMIT=24000
SKILL_RETRIEVAL_TOP_K=36
SKILL_PRESELECT_MULTIPLIER=10
SKILL_PRESELECT_MIN=120
SKILL_PRESELECT_MAX=420
SKILL_SEMANTIC_PREVIEW_COUNT=40
